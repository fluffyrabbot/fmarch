# Railway API service variables. Set these in Railway, never in the repository.
# DATABASE_URL should be a Railway reference variable to the project Postgres service.
DATABASE_URL=${{Postgres.DATABASE_URL}}
FMARCH_MEDIA_ROOT=/var/lib/fmarch/media
RUST_LOG=info
# Optional hosted identity delivery transport. Set the auth token from Railway's secret store.
# FMARCH_IDENTITY_DELIVERY_ENDPOINT=https://provider.example.test/v1/deliveries
# FMARCH_IDENTITY_DELIVERY_PROVIDER_ID=http-json
# FMARCH_IDENTITY_DELIVERY_AUTH_TOKEN=${{IDENTITY_DELIVERY_AUTH_TOKEN}}
