# Railway API service variables. Set these in Railway, never in the repository.
# DATABASE_URL should be a Railway reference variable to the project Postgres service.
DATABASE_URL=${{Postgres.DATABASE_URL}}
FMARCH_MEDIA_ROOT=/var/lib/fmarch/media
RUST_LOG=info
# Bind dual-stack so the frontend can reach this service over Railway private
# networking (IPv6-only). Without this the server binds 0.0.0.0:$PORT and
# fmarch.railway.internal is unreachable.
FMARCH_BIND=[::]:8080
# Capacity defaults. Tune only from hosted measurements; keep queues bounded.
FMARCH_DB_MAX_CONNECTIONS=10
FMARCH_DB_ACQUIRE_TIMEOUT_MS=250
FMARCH_DB_STATEMENT_TIMEOUT_MS=5000
FMARCH_DB_LOCK_TIMEOUT_MS=1000
FMARCH_DB_IDLE_TRANSACTION_TIMEOUT_MS=10000
FMARCH_HTTP_MAX_IN_FLIGHT=128
FMARCH_HTTP_QUEUE_TIMEOUT_MS=50
FMARCH_HTTP_REQUEST_TIMEOUT_MS=15000
FMARCH_HTTP_RETRY_AFTER_SECONDS=1
FMARCH_WS_MAX_CONNECTIONS=512
FMARCH_LIVE_PROJECTION_CAPACITY=256
# The image prepares Railway's root-owned volume, then starts the server as UID 10001.
# Do not set RAILWAY_RUN_UID; the entrypoint must perform the privilege drop.
# Optional hosted identity delivery transport. Set the auth token from Railway's secret store.
# FMARCH_IDENTITY_DELIVERY_ENDPOINT=https://provider.example.test/v1/deliveries
# FMARCH_IDENTITY_DELIVERY_PROVIDER_ID=http-json
# FMARCH_IDENTITY_DELIVERY_AUTH_TOKEN=${{IDENTITY_DELIVERY_AUTH_TOKEN}}
