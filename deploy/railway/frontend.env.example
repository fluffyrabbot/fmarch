# Railway frontend service variables. Replace the example URLs with staging URLs.
ORIGIN=https://fmarch-staging.example.com
# Public API base: used for URLs handed to the browser (live websocket).
FMARCH_API_BASE_URL=https://api.fmarch-staging.example.com
# Private-network API base for SSR fetches. Requires the API to bind IPv6
# (FMARCH_BIND=[::]:PORT); Railway private networking is IPv6-only.
FMARCH_API_INTERNAL_URL=http://fmarch.railway.internal:8080
# Per-fetch SSR budget in ms (0 disables). Cold loads fall back to fixture
# payloads when the API exceeds it.
# FMARCH_SSR_FETCH_TIMEOUT_MS=2000
# Auth-session resolution cache TTL in ms (0 disables).
# FMARCH_SESSION_CACHE_TTL_MS=30000
