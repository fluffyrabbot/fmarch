{
  "version": 1,
  "artifact_freshness_max_age_seconds": 86400,
  "database_url_example": "postgres://fmarch:fmarch@localhost:5544/fmarch",
  "families": [
    {
      "heading": "Game-Specific Audits",
      "runs": [
        {
          "id": "projection-rebuild-audit",
          "family": "Projection rebuild audit",
          "scope": "Game-specific",
          "command_template": "DATABASE_URL={database_url} cargo run -p projections --bin audit_rebuild -- {game}",
          "proof_boundary": "Replays this game stream inside a rollback-only transaction."
        },
        {
          "id": "resolution-replay-audit",
          "family": "Resolution replay audit",
          "scope": "Game-specific",
          "command_template": "DATABASE_URL={database_url} cargo run -p commands --bin audit_resolution -- {game}",
          "proof_boundary": "Rebuilds stored resolution envelopes for this game and reports drift."
        },
        {
          "id": "resolution-trace-inspection",
          "family": "Resolution trace inspection",
          "scope": "Game-specific",
          "command_template": "DATABASE_URL={database_url} cargo run -p commands --bin inspect_trace -- {game}",
          "proof_boundary": "Flattens stored trace rows for this game; optional run_id remains CLI-only."
        }
      ]
    },
    {
      "heading": "Local-Only Regression Lanes",
      "runs": [
        {
          "id": "large-action-graph-regression",
          "family": "Large action graph regression",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands large_action_graph_resolves_and_audits_within_regression_ceiling -- --nocapture",
          "test_selector": "large_action_graph_resolves_and_audits_within_regression_ceiling",
          "proof_boundary": "Fixed dense Mafiascum N01 graph with replay, trace, rebuild, and duration ceilings."
        },
        {
          "id": "seeded-day-vote-replay",
          "family": "Seeded day-vote replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline seeded_day_vote_scenarios_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "seeded_day_vote_scenarios_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Fixed day-vote seeds through command resolution and the audit trio."
        },
        {
          "id": "seeded-mafiascum-night-graph-replay",
          "family": "Seeded Mafiascum night graph replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline seeded_night_action_graphs_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "seeded_night_action_graphs_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Fixed night-action seeds across protect, roleblock, tracking, watching, redirect, and kill families."
        },
        {
          "id": "seeded-trigger-dependency-replay",
          "family": "Seeded trigger/dependency replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline seeded_trigger_dependency_graphs_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "seeded_trigger_dependency_graphs_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Fixed PGO, Babysitter, and Hider trigger/dependency seeds under replay, trace, and rebuild audits."
        },
        {
          "id": "seeded-persistent-trigger-replay",
          "family": "Seeded persistent trigger replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline seeded_persistent_trigger_state_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "seeded_persistent_trigger_state_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Two-phase Hunter retaliation and Cupid/Lovers folded state consumed by later resolution."
        },
        {
          "id": "seeded-day-trigger-policy-replay",
          "family": "Seeded day-trigger policy replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline seeded_day_trigger_policy_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "seeded_day_trigger_policy_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Super-Saint lynch and Hero/VoteDuel day triggers under replay, trace, and rebuild audits."
        },
        {
          "id": "generated-mafiascum-night-replay",
          "family": "Generated Mafiascum night replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline generated_night_action_graphs_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "generated_night_action_graphs_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Bounded generated N01 cases with seed/roster/action failure output."
        },
        {
          "id": "generated-chinese-structured-night-replay",
          "family": "Generated Chinese Structured night replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline generated_chinese_structured_night_graphs_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "generated_chinese_structured_night_graphs_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Chinese Structured N01 fixed seeds across wolf, witch, guard, prophet, cupid, hunter, and passive roles."
        },
        {
          "id": "generated-chinese-structured-day-replay",
          "family": "Generated Chinese Structured day replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline generated_chinese_structured_day_graphs_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "generated_chinese_structured_day_graphs_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Chinese Structured D01 fixed seeds for sheriff election, Knight duel, self-destruct, and votes."
        },
        {
          "id": "generated-mafia-universe-ita-replay",
          "family": "Generated Mafia Universe ITA replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline generated_mafia_universe_ita_sessions_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "generated_mafia_universe_ita_sessions_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Mafia Universe D01 ITA fixed seeds with deterministic hit/miss outcomes and audit trio."
        },
        {
          "id": "generated-epicmafia-prompt-night-replay",
          "family": "Generated Epicmafia prompt/night replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline generated_epicmafia_pk_bomb_cult_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "generated_epicmafia_pk_bomb_cult_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Epicmafia PK prompt and Bomb/Cult night fixed seeds under replay, trace, and rebuild audits."
        },
        {
          "id": "generated-default-open-night-replay",
          "family": "Generated default_open night replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline generated_default_open_night_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "generated_default_open_night_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Copyright-free default_open N01 seeds under the same audit trio."
        },
        {
          "id": "generated-default-open-day-replay",
          "family": "Generated default_open day replay",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline generated_default_open_day_replay_audit_and_rebuild_deterministically -- --nocapture",
          "test_selector": "generated_default_open_day_replay_audit_and_rebuild_deterministically",
          "proof_boundary": "Copyright-free default_open D01 vote seeds under the same audit trio."
        },
        {
          "id": "night-fixture-minimizer",
          "family": "Night fixture minimizer",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin minimize_night_fixture -- crates/commands/fixtures/night-passing.json",
          "proof_boundary": "Replays a checked-in fixture; add --reduce only when preserving a captured failure class."
        },
        {
          "id": "checked-game-specific-audit-bundle",
          "family": "Checked game-specific audit bundle",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin prove_game_specific_audits -- --output target/operator-proof/game-specific-audit-bundle-20260613T000000Z.json crates/commands/fixtures/night-passing.json",
          "artifact_path": "target/operator-proof/game-specific-audit-bundle-20260613T000000Z.json",
          "proof_boundary": "Seeds a fixture-backed game, expands the manifest's game-specific command templates for that id, executes them, and fails on mismatched audit counts."
        },
        {
          "id": "game-specific-audit-artifact-retention",
          "family": "Game-specific audit artifact retention",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin prove_game_specific_audits -- --compare-with target/operator-proof/game-specific-audit-bundle-20260613T000000Z.json --output target/operator-proof/game-specific-audit-bundle-20260613T001500Z.json crates/commands/fixtures/night-passing.json",
          "artifact_path": "target/operator-proof/game-specific-audit-bundle-20260613T001500Z.json",
          "proof_boundary": "Regenerates the checked game-specific bundle and fails unless the old and new reports match after normalizing expected rerun drift fields."
        },
        {
          "id": "operator-proof-status-export",
          "family": "Operator proof status export",
          "scope": "Local-only",
          "command_template": "cargo run -q -p commands --bin export_operator_proof_status -- --fixture artifact-provenance --output target/operator-proof/current-status-audit-check.json 00000000-0000-0000-0000-000000000000",
          "proof_boundary": "Exports the artifact-provenance proof-run status contract without starting Axum, touching Postgres, or executing proof commands."
        },
        {
          "id": "operator-proof-status-snapshot-audit",
          "family": "Operator proof status snapshot audit",
          "scope": "Local-only",
          "command_template": "cargo run -q -p commands --bin audit_operator_proof_status -- --output target/operator-proof/current-status-audit-report.json crates/commands/fixtures/operator-proof-status-artifact-provenance.snapshot.json target/operator-proof/current-status-audit-check.json",
          "artifact_path": "target/operator-proof/current-status-audit-report.json",
          "artifact_kind": "operator_proof_status_audit_report",
          "audit_expected_path": "crates/commands/fixtures/operator-proof-status-artifact-provenance.snapshot.json",
          "audit_actual_path": "target/operator-proof/current-status-audit-check.json",
          "proof_boundary": "Compares the saved normalized artifact-provenance status snapshot against the latest exported status, writes the audit report artifact, and fails on row-addressed contract drift."
        },
        {
          "id": "operator-proof-artifact-go-no-go",
          "family": "Operator proof artifact go/no-go",
          "scope": "Local-only",
          "command_template": "cargo run -q -p commands --bin audit_operator_proof_artifacts -- --output target/operator-proof/current-artifact-go-no-go-report.json 00000000-0000-0000-0000-000000000000",
          "artifact_path": "target/operator-proof/current-artifact-go-no-go-report.json",
          "artifact_kind": "operator_proof_go_no_go_report",
          "proof_boundary": "Loads the published proof-run manifest, classifies artifact-provenance rows, writes the compact go/no-go report with trusted metadata for artifact rows that have proof-specific counters, and fails if any production artifact row is not trusted."
        },
        {
          "id": "operator-proof-artifact-retention",
          "family": "Operator proof artifact retention",
          "scope": "Local-only",
          "command_template": "cargo run -q -p commands --bin audit_operator_proof_artifact_retention -- --output target/operator-proof/current-artifact-retention-report.json target/operator-proof/previous-artifact-go-no-go-report.json target/operator-proof/current-artifact-go-no-go-report.json",
          "artifact_path": "target/operator-proof/current-artifact-retention-report.json",
          "artifact_kind": "operator_proof_go_no_go_retention_report",
          "proof_boundary": "Compares the previous and current go/no-go reports after normalizing wall-clock freshness and fails on production artifact state regressions."
        },
        {
          "id": "operator-proof-projection-rebuild",
          "family": "Operator proof projection rebuild",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin audit_projection_rebuild_artifact -- --output target/operator-proof/current-projection-rebuild-report.json 08d8a45f-6c3b-4401-8e31-8d7637f36a82",
          "artifact_path": "target/operator-proof/current-projection-rebuild-report.json",
          "artifact_kind": "projection_rebuild_audit_report",
          "proof_boundary": "Runs the projection rebuild audit for the checked fixture game inside a rollback-only transaction, writes a versioned report with table counts, and fails on rebuild drift."
        },
        {
          "id": "operator-proof-resolution-diff",
          "family": "Operator proof resolution diff",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin audit_resolution_diff_artifact -- --output target/operator-proof/current-resolution-diff-report.json 08d8a45f-6c3b-4401-8e31-8d7637f36a82",
          "artifact_path": "target/operator-proof/current-resolution-diff-report.json",
          "artifact_kind": "resolution_diff_report",
          "proof_boundary": "Runs the resolution replay diff for the checked fixture game, writes a versioned report with normalized stream-detail fields and row-addressed envelope diffs, and fails on resolution drift."
        },
        {
          "id": "operator-proof-trace-inspection",
          "family": "Operator proof trace inspection",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin audit_trace_inspection_artifact -- --output target/operator-proof/current-trace-inspection-report.json 08d8a45f-6c3b-4401-8e31-8d7637f36a82",
          "artifact_path": "target/operator-proof/current-trace-inspection-report.json",
          "artifact_kind": "trace_inspection_report",
          "proof_boundary": "Exports the host/admin trace inspection for the checked fixture game, writes a versioned report with normalized stream fields and row-count summaries, and fails when no stored trace is available."
        },
        {
          "id": "operator-proof-large-action-graph-performance",
          "family": "Operator proof large action graph performance",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin audit_large_action_graph_performance_artifact -- --output target/operator-proof/current-large-action-graph-performance-report.json",
          "artifact_path": "target/operator-proof/current-large-action-graph-performance-report.json",
          "artifact_kind": "large_action_graph_performance_report",
          "proof_boundary": "Runs the dense Mafiascum N01 large-action-graph scenario, writes a versioned report with fixture dimensions, replay/projection status, trace row count, explicit phase/decision trace anchoring flags, elapsed milliseconds, and the configured regression ceiling, and fails when the ceiling, audits, or trace anchors fail."
        },
        {
          "id": "operator-proof-determinism-fuzz",
          "family": "Operator proof determinism fuzz",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin audit_determinism_fuzz_artifact -- --output target/operator-proof/current-determinism-fuzz-report.json",
          "artifact_path": "target/operator-proof/current-determinism-fuzz-report.json",
          "artifact_kind": "determinism_fuzz_report",
          "proof_boundary": "Runs the known seeded command-pipeline replay/projection/trace scenario families as local Postgres integration tests, writes a versioned report with exact expected family/seed manifest coverage and first failing seed, and fails on failed, missing, or manifest-mismatched seeded families; this is deterministic generator coverage, not exhaustive state-space verification."
        },
        {
          "id": "operator-proof-generated-shrink-matrix",
          "family": "Operator proof generated shrink matrix",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo test -p commands --test pipeline generated_shrink_matrix_writes_compact_operator_report -- --nocapture && test -f target/operator-proof/current-generated-shrink-matrix-report.tmp.json",
          "test_selector": "generated_shrink_matrix_writes_compact_operator_report",
          "artifact_path": "target/operator-proof/current-generated-shrink-matrix-report.tmp.json",
          "artifact_kind": "generated_shrink_matrix_report",
          "proof_boundary": "Runs the bounded deterministic generated shrink matrix for PGO, PgoProjectionState, Babysitter, BabysitterProjectionState, Hider, HiderProjectionState, Hunter, HunterProjectionState, VengefulFixpoint, VengefulProjectionState, StrongmanVengefulFixpoint, StrongmanVengefulProjectionState, BodyguardStrongmanVengefulFixpoint, BodyguardStrongmanVengefulProjectionState, BackupInheritance, BackupProjectionState, ConversionDeprogramming, ConversionProjectionState, MarkClearVisibility, MarkClearExpiry, PoisonCure, Ignite, ExtraAction, ItemGrant, PrivateNotification, Lovers, LoversProjectionState, Bomb, and BombProjectionState against local Postgres, writes a versioned report with two cases per family plus success and bad-expectation shrink preservation metadata, and does not prove exhaustive randomized coverage."
        },
        {
          "id": "operator-proof-command-projection-resolution",
          "family": "Operator proof command/projection resolution",
          "scope": "Local-only",
          "command_template": "DATABASE_URL={database_url} cargo run -q -p commands --bin prove_command_projection_resolution -- --output target/operator-proof/current-command-projection-resolution-report.json crates/commands/fixtures/night-passing.json",
          "artifact_path": "target/operator-proof/current-command-projection-resolution-report.json",
          "artifact_kind": "command_projection_resolution_report",
          "proof_boundary": "Local-Postgres-only proof: seeds the checked fixture through commands::handle, runs Command::ResolvePhase against the local DATABASE_URL Postgres service, compares resolution replay and projection rebuild results for that generated game, writes the saved report under target/operator-proof, and does not prove hosted, multi-node, production, browser, or exhaustive state-space behavior."
        }
      ]
    }
  ]
}
