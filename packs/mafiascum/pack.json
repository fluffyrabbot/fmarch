  "precedence": [
    {
      "id": "block_stops_roleblockable",
      "when": { "effect": "Block", "target_state": null },
      "beats": ["Kill", "Protect", "Investigate", "Redirect"],
      "blocked_by": [],
      "unless_modifiers": [],
      "notes": "A Block prevents the blocked slot's roleblockable action from resolving. Only abilities whose action carries roleblockable=true are stopped; the Roleblocker's own Block is not roleblockable. Block is the highest-priority interaction and is evaluated before targets are read by the blocked action."
    },
    {
      "id": "redirect_before_targets_read",
      "when": { "effect": "Redirect", "target_state": null },
      "beats": ["Kill", "Protect", "Investigate"],
      "blocked_by": ["Block"],
      "unless_modifiers": [],
      "notes": "Redirect (bus drive) rewrites target maps before Kill/Protect/Investigate read their targets. A roleblocked bus driver does not swap. Resolved under RedirectPolicy with loop_cap."
    },
    {
      "id": "protect_beats_kill",
      "when": { "effect": "Protect", "target_state": null },
      "beats": ["Kill"],
      "blocked_by": ["Block"],
      "unless_modifiers": ["Strongman"],
      "notes": "Doctor's Protect saves the target from a Kill, UNLESS the killing action carries the Strongman modifier. A roleblocked doctor does not protect."
    },
    {
      "id": "kill_resolves",
      "when": { "effect": "Kill", "target_state": null },
      "beats": [],
      "blocked_by": ["Block", "Protect"],
      "unless_modifiers": [],
      "notes": "A Kill removes the target from play unless stopped by Block (roleblocked killer) or Protect (doctored target). Strongman is handled by protect_beats_kill's unless_modifiers, which removes Protect from this Kill's blocked_by at evaluation time."
    }
  ],
  "visibility": {
    "Investigate": {
      "sees": ["TargetId", "Result"],
      "unless_modifiers": ["Ninja"]
    },
    "Kill": {
      "sees": ["TargetId"],
      "unless_modifiers": ["Ninja"]
    },
    "Protect": {
      "sees": ["TargetId"],
      "unless_modifiers": []
    },
    "Block": {
      "sees": ["TargetId"],
      "unless_modifiers": []
    },
    "Redirect": {
      "sees": ["TargetId"],
      "unless_modifiers": ["Ninja"]
    }
  },
  "redirects": {
    "order": ["Redirect"],
    "loop_cap": 8,
    "tie_breaker": "Stable"
  },
  "triggers": [],
  "vote": {
    "method": "Plurality",
    "no_lynch_allowed": true,
    "self_vote_allowed": false,
    "hammer": false,
    "weights": "Equal",
    "tie_breaker": "NoElimination"
  },
  "phases": {
