DATABASE_URL=postgres://fmarch:fmarch@localhost:5544/fmarch
FMARCH_EVENT_ENCRYPTION_KEY=replace-with-32-byte-base64-key-or-local-passphrase
FMARCH_EVENT_ENCRYPTION_KID=local-dev
FMARCH_AUTH_SOURCE_SIGNING_KEY=replace-with-at-least-32-random-bytes
# Explicit local-only identity proof mode. Remove this and configure all three
# API WorkOS variables for any shared or hosted environment.
FMARCH_DEV_AUTH=1
